{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@ava/contracts": ["../contracts/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../contracts/src/**/*"]
}
