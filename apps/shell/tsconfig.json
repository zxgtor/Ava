{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@ava/plugin-sdk": ["../../packages/ava-plugin-sdk/src/index.ts"]
    }
  },
  "include": ["src/**/*", "electron/**/*", "electron.vite.config.ts"],
  "exclude": ["node_modules", "out", "dist"]
}
